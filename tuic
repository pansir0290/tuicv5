#!/bin/bash
# 强制切换输入源到终端
exec </dev/tty

# 颜色定义
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== TUIC v5 最终自适应部署脚本 ===${NC}"

# 1. 输入域名
read -p "请输入你的真实解析域名 (将作为 SNI 使用): " DOMAIN
if [ -z "$DOMAIN" ]; then
    echo -e "${RED}域名不能为空，脚本已终止。${NC}"
    exit 1
fi

# 2. 自动探测系统架构并下载对应二进制文件
ARCH=$(uname -m)
echo "正在检测架构: $ARCH ..."

if [ "$ARCH" == "aarch64" ]; then
    DOWNLOAD_URL="https://github.com/EAimTY/tuic/releases/download/tuic-server-1.0.0/tuic-server-1.0.0-aarch64-linux-gnu"
else
    DOWNLOAD_URL="https://github.com/EAimTY/tuic/releases/download/tuic-server-1.0.0/tuic-server-1.0.0-x86_64-linux-gnu"
fi

echo "正在从 $DOWNLOAD_URL 下载..."
mkdir -p /usr/local/bin/tuic /etc/tuic
wget -O /usr/local/bin/tuic-server "$DOWNLOAD_URL"
chmod +x /usr/local/bin/tuic-server

# 3. 搜索证书
CERT_PATH=$(find /root/npm/letsencrypt/live/ -name "fullchain.pem" | grep "$DOMAIN" | head -n 1)
KEY_PATH=$(find /root/npm/letsencrypt/live/ -name "privkey.pem" | grep "$DOMAIN" | head -n 1)

if [ -z "$CERT_PATH" ]; then
    echo -e "${RED}未找到证书，请先在 NPM 面板申请证书。${NC}"
    exit 1
fi

# 4. 生成配置 (纯十六进制 Token，避开特殊符号)
UUID=$(cat /proc/sys/kernel/random/uuid)
TOKEN=$(openssl rand -hex 16)

cat > /etc/tuic/config.json <<EOF
{
  "server": "0.0.0.0:4443",
  "users": { "$UUID": "$TOKEN" },
  "certificate": "$CERT_PATH",
  "private_key": "$KEY_PATH",
  "congestion_controller": "bbr",
  "alpn": ["h3"],
  "packet_loss_prevention": true
}
EOF

# 5. 系统服务
cat > /etc/systemd/system/tuic.service <<EOF
[Unit]
Description=TUIC v5 Server
After=network.target

[Service]
ExecStart=/usr/local/bin/tuic-server -c /etc/tuic/config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload && systemctl enable tuic && systemctl restart tuic

# 6. 输出结果
IP=$(curl -s4 ifconfig.me)
echo -e "\n${GREEN}部署成功！${NC}"
echo "----------------------------------------------------"
echo "TUIC 链接:"
echo "tuic://$UUID:$TOKEN@$IP:4443/?sni=$DOMAIN&congestion_control=bbr&packet_loss_prevention=1&alpn=h3"
echo "----------------------------------------------------"
echo "使用提示：如果连接不通，请在防火墙/安全组放行 4443/UDP 端口。"
