#!/bin/bash
exec </dev/tty

# 颜色定义
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== TUIC v5 最终部署脚本 (已优化兼容性) ===${NC}"

# 1. 输入域名
read -p "请输入你的真实解析域名 (将作为 SNI 使用): " DOMAIN
if [ -z "$DOMAIN" ]; then
    echo -e "${RED}域名不能为空，脚本已终止。${NC}"
    exit 1
fi

# 2. 搜索证书 (兼容 NPM)
CERT_PATH=$(find /root/npm/letsencrypt/live/ -name "fullchain.pem" | grep "$DOMAIN" | head -n 1)
KEY_PATH=$(find /root/npm/letsencrypt/live/ -name "privkey.pem" | grep "$DOMAIN" | head -n 1)

# 3. 未找到证书引导申请
if [ -z "$CERT_PATH" ]; then
    read -p "未找到证书，是否申请？(y/n): " APPLY_NEW
    if [[ "$APPLY_NEW" == "y" ]]; then
        apt update && apt install -y certbot
        certbot certonly --standalone -d "$DOMAIN" --non-interactive --agree-tos -m admin@$DOMAIN
        CERT_PATH="/etc/letsencrypt/live/$DOMAIN/fullchain.pem"
        KEY_PATH="/etc/letsencrypt/live/$DOMAIN/privkey.pem"
    else
        exit 1
    fi
fi

# 4. 生成 UUID 和 纯十六进制 TOKEN (无特殊字符)
UUID=$(cat /proc/sys/kernel/random/uuid)
TOKEN=$(openssl rand -hex 16)

# 5. 配置 TUIC
mkdir -p /usr/local/bin/tuic /etc/tuic
wget -qO /usr/local/bin/tuic-server https://github.com/EAimTY/tuic/releases/download/tuic-server-1.0.0/tuic-server-1.0.0-x86_64-linux-gnu
chmod +x /usr/local/bin/tuic-server

cat > /etc/tuic/config.json <<EOF
{
  "server": "0.0.0.0:4443",
  "users": { "$UUID": "$TOKEN" },
  "certificate": "$CERT_PATH",
  "private_key": "$KEY_PATH",
  "congestion_controller": "bbr",
  "alpn": ["h3"],
  "packet_loss_prevention": true
}
EOF

# 6. 系统服务
cat > /etc/systemd/system/tuic.service <<EOF
[Unit]
Description=TUIC v5 Server
After=network.target

[Service]
ExecStart=/usr/local/bin/tuic-server -c /etc/tuic/config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload && systemctl restart tuic

# 7. 输出结果
IP=$(curl -s4 ifconfig.me)
echo -e "\n${GREEN}部署成功！${NC}"
echo "----------------------------------------------------"
echo "TUIC 链接:"
echo "tuic://$UUID:$TOKEN@$IP:4443/?sni=$DOMAIN&congestion_control=bbr&packet_loss_prevention=1&alpn=h3"
echo "----------------------------------------------------"
